DATABASE_URL=postgres://lahzo:lahzo@localhost:5432/lahzo
DATABASE_POOL_MAX=10

SMS_GATEWAY=mock

# Simple Twilio auth. Set SMS_GATEWAY=twilio and fill these values to send real outbound SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional API key auth alternative.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Optional. If set, outbound sends use the messaging service instead of the inbound To number as From.
TWILIO_MESSAGING_SERVICE_SID=

SIMULATED_DELAY_MIN_MS=3000
SIMULATED_DELAY_MAX_MS=15000
WORKER_ID=
